# ─── ChatForge Production Environment ─────────────────────────────────────────
# Скопируйте в .env.prod и заполните значения:
#   cp .env.prod.example .env.prod
#
# Запуск:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ─── Домен ────────────────────────────────────────────────────────────────────
# Основной домен без протокола и слеша
DOMAIN=yourdomain.com

# Email для Let's Encrypt уведомлений
ACME_EMAIL=admin@yourdomain.com

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=chatforge
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=chatforge_prod

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=chatforge

# ─── Phoenix Security ─────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -base64 64
SECRET_KEY_BASE=CHANGE_ME_min_64_chars_secret_key_base_generate_with_openssl

# Сгенерировать: openssl rand -base64 64
GUARDIAN_SECRET_KEY=CHANGE_ME_min_64_chars_guardian_secret_generate_with_openssl

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL для открытия чат-инстанса (с {subdomain} плейсхолдером)
# Если используете субдомены: https://{subdomain}.yourdomain.com
# Если используете query param: https://yourdomain.com/?subdomain={subdomain}
VITE_CHAT_BASE_URL=https://yourdomain.com/?subdomain={subdomain}

# Публичный URL MinIO для аватаров
S3_PUBLIC_URL=https://minio.yourdomain.com
