# ─── ChatForge Production Environment ─────────────────────────────────────────
# Скопируйте в .env.prod и заполните значения:
#   cp .env.prod.example .env.prod
#
# Запуск (после того как глобальный Traefik уже запущен):
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# ─── Домен ────────────────────────────────────────────────────────────────────
# Домен ChatForge без протокола и слеша
# Например: chatforge.yourdomain.com или просто yourdomain.com
DOMAIN=chatforge.yourdomain.com

# ─── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=chatforge
POSTGRES_PASSWORD=CHANGE_ME_strong_password
POSTGRES_DB=chatforge_prod

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_password
MINIO_BUCKET=chatforge

# ─── Phoenix Security ─────────────────────────────────────────────────────────
# Сгенерировать: openssl rand -base64 64
SECRET_KEY_BASE=CHANGE_ME_min_64_chars_secret_key_base_generate_with_openssl

# Сгенерировать: openssl rand -base64 64
GUARDIAN_SECRET_KEY=CHANGE_ME_min_64_chars_guardian_secret_generate_with_openssl

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini
AI_BASE_URL=https://api.openai.com/v1

# ─── Super Admin (создаётся автоматически при первом запуске) ─────────────────
SEED_ADMIN_EMAIL=admin@chatforge.dev
SEED_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ─── URLs ─────────────────────────────────────────────────────────────────────
# URL для открытия чат-инстанса (с {subdomain} плейсхолдером)
# Вариант А — через query param (проще, не нужен wildcard DNS):
VITE_CHAT_BASE_URL=https://chatforge.yourdomain.com/?subdomain={subdomain}
# Вариант Б — через субдомены (нужен wildcard DNS *.chatforge.yourdomain.com):
# VITE_CHAT_BASE_URL=https://{subdomain}.chatforge.yourdomain.com

# Публичный URL MinIO для аватаров
S3_PUBLIC_URL=https://minio.chatforge.yourdomain.com
