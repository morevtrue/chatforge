# ─── Пример переменных окружения для ChatForge ────────────────────────────
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env
#
# ВАЖНО: Никогда не коммитьте .env в репозиторий!

# ─── База данных (PostgreSQL) ──────────────────────────────────────────────
# Полный URL подключения к PostgreSQL
DATABASE_URL=postgresql://chatforge:your_password_here@localhost:5432/chatforge_dev

# Учётные данные PostgreSQL (используются в docker-compose.yml)
POSTGRES_USER=chatforge
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=chatforge_dev

# ─── Кеш и сессии (Redis) ─────────────────────────────────────────────────
# URL подключения к Redis
REDIS_URL=redis://localhost:6379

# ─── Безопасность Phoenix ─────────────────────────────────────────────────
# Секретный ключ для подписи сессий и токенов (минимум 64 символа)
# Сгенерировать: mix phx.gen.secret
SECRET_KEY_BASE=your_secret_key_base_here_minimum_64_characters_long_replace_this

# ─── Файловое хранилище (MinIO / S3) ──────────────────────────────────────
# Логин администратора MinIO
MINIO_ROOT_USER=minioadmin

# Пароль администратора MinIO (минимум 8 символов)
MINIO_ROOT_PASSWORD=your_minio_password_here

# Название бакета для хранения файлов (аватары, медиа)
MINIO_BUCKET=chatforge-uploads

# ─── Опциональные настройки ───────────────────────────────────────────────
# Порт Phoenix-сервера (по умолчанию: 4000)
# PORT=4000

# Разрешённые CORS-origins для фронтенда (по умолчанию: http://localhost:5173)
# CORS_ORIGINS=http://localhost:5173
OPENAI_API_KEY=
AI_MODEL=
AI_BASE_URL=

# ─── Frontend ─────────────────────────────────────────────────────────────
# Базовый URL для открытия чат-инстанса
# Dev: ?subdomain= параметр (не требует настройки hosts файла)
# Prod: субдомен-based URL, например https://{subdomain}.chatforge.app
VITE_CHAT_BASE_URL=http://localhost:5173/?subdomain={subdomain}